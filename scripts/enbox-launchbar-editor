#!/usr/bin/env python3
import configparser
import hashlib
import os
import shutil
import subprocess
import sys
import time
from PIL import Image, ImageTk
from dataclasses import dataclass
from pathlib import Path
import tkinter as tk
from tkinter import ttk, filedialog, messagebox

CONFIG_DEFAULT = Path("~/.config/tint2/tint2rc-launchbar").expanduser()

ICON_SIZES_PREFERRED = [16, 24, 32]
ICON_EXTS = [".png", ".xpm", ".svg"]  # prefer png/xpm; svg may be converted if possible

@dataclass
class LauncherItem:
    desktop_path: Path
    name: str
    icon_key: str
    icon_path: Path | None


def read_desktop_entry(desktop_file: Path) -> tuple[str, str]:
    cp = configparser.ConfigParser(interpolation=None, strict=False)
    cp.optionxform = str  # preserve case of keys
    try:
        with desktop_file.open("r", encoding="utf-8", errors="replace") as f:
            cp.read_file(f)
    except Exception:
        return (desktop_file.stem, "")

    section = "Desktop Entry"
    if section not in cp:
        return (desktop_file.stem, "")

    name = cp[section].get("Name", desktop_file.stem).strip()
    icon = cp[section].get("Icon", "").strip()
    return (name, icon)


def _which(cmd: str) -> str | None:
    return shutil.which(cmd)


def convert_svg_to_png(svg_path: Path, out_png: Path) -> bool:
    """
    Best-effort conversion using common CLI tools.
    Tries: rsvg-convert, inkscape, magick/convert.
    """
    out_png.parent.mkdir(parents=True, exist_ok=True)

    if _which("rsvg-convert"):
        cmd = ["rsvg-convert", "-o", str(out_png), str(svg_path)]
    elif _which("inkscape"):
        # inkscape 1.x
        cmd = ["inkscape", str(svg_path), "--export-type=png", f"--export-filename={out_png}"]
    elif _which("magick"):
        cmd = ["magick", str(svg_path), str(out_png)]
    elif _which("convert"):
        cmd = ["convert", str(svg_path), str(out_png)]
    else:
        return False

    try:
        subprocess.run(cmd, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return out_png.exists()
    except Exception:
        return False


def icon_cache_path_for(src: Path) -> Path:
    h = hashlib.sha256(str(src).encode("utf-8")).hexdigest()[:16]
    cache_dir = Path("~/.cache/tint2-quicklaunch-editor/icons").expanduser()
    return cache_dir / f"{h}.png"


def resolve_icon(icon_key: str) -> Path | None:
    """
    Resolve a .desktop Icon= value to an image file usable by Tk.
    - If it's an absolute/relative path: use it (png/xpm) or convert svg.
    - If it's a themed icon name: search common icon dirs for png/xpm, convert svg if found.
    """
    if not icon_key:
        return None

    # Path-like?
    p = Path(icon_key).expanduser()
    if p.is_absolute() or str(icon_key).startswith(("~/", "./", "../")):
        if p.exists():
            if p.suffix.lower() in (".png", ".xpm"):
                return p
            if p.suffix.lower() == ".svg":
                out = icon_cache_path_for(p)
                if out.exists() or convert_svg_to_png(p, out):
                    return out
        return None

    # Themed icon name: search common locations
    icon_name = icon_key

    # Common icon roots
    roots = [
        Path("~/.local/share/icons").expanduser(),
        Path("~/.icons").expanduser(),
        Path("/usr/local/share/icons"),
        Path("/usr/share/icons"),
        Path("/usr/share/pixmaps"),
    ]

    # 1) /usr/share/pixmaps often has direct png/xpm with appname
    pixmaps = Path("/usr/share/pixmaps")
    for ext in (".png", ".xpm", ".svg"):
        cand = pixmaps / f"{icon_name}{ext}"
        if cand.exists():
            if ext in (".png", ".xpm"):
                return cand
            out = icon_cache_path_for(cand)
            if out.exists() or convert_svg_to_png(cand, out):
                return out

    # 2) Icon theme hierarchy search (best-effort):
    # Look for .../hicolor/*x*/apps/<name>.<ext> etc.
    # Also allow "scalable" svg.
    patterns = []
    for size in ICON_SIZES_PREFERRED:
        patterns.append(f"**/{size}x{size}/**/{icon_name}.*")
    patterns.append(f"**/scalable/**/{icon_name}.*")

    best_png = None
    best_xpm = None
    best_svg = None

    for root in roots:
        if not root.exists() or not root.is_dir():
            continue
        for pat in patterns:
            for cand in root.glob(pat):
                if not cand.is_file():
                    continue
                ext = cand.suffix.lower()
                if ext == ".png" and best_png is None:
                    best_png = cand
                elif ext == ".xpm" and best_xpm is None:
                    best_xpm = cand
                elif ext == ".svg" and best_svg is None:
                    best_svg = cand

            if best_png:
                return best_png
            if best_xpm:
                return best_xpm

    if best_svg:
        out = icon_cache_path_for(best_svg)
        if out.exists() or convert_svg_to_png(best_svg, out):
            return out

    return None


def parse_tint2_launchers(config_path: Path) -> list[Path]:
    launchers: list[Path] = []
    if not config_path.exists():
        return launchers

    for line in config_path.read_text(encoding="utf-8", errors="replace").splitlines():
        s = line.strip()
        if not s.startswith("launcher_item_app"):
            continue
        # formats seen: launcher_item_app = PATH
        if "=" not in s:
            continue
        _, rhs = s.split("=", 1)
        path_str = rhs.strip()
        if not path_str:
            continue
        launchers.append(Path(path_str).expanduser())
    return launchers


def write_tint2_launchers(config_path: Path, launcher_paths: list[Path]) -> None:
    """
    Rewrites config_path, replacing the contiguous block of launcher_item_app lines
    (from first to last occurrence) with the new list. If none exist, appends at end.
    Creates a timestamped backup next to the file.
    """
    text = config_path.read_text(encoding="utf-8", errors="replace").splitlines(True)  # keep newlines
    indices = [i for i, line in enumerate(text) if line.strip().startswith("launcher_item_app")]

    new_lines = [f"launcher_item_app = {str(p)}\n" for p in launcher_paths]

    backup = config_path.with_suffix(config_path.suffix + f".bak-{time.strftime('%Y%m%d-%H%M%S')}")
    backup.write_text("".join(text), encoding="utf-8")

    if indices:
        start, end = indices[0], indices[-1]
        # Replace that range (inclusive)
        out = text[:start] + new_lines + text[end + 1 :]
    else:
        # Append with a preceding newline if file doesn't end with one
        out = text[:]
        if out and not out[-1].endswith("\n"):
            out[-1] += "\n"
        if out and out[-1] != "\n":
            out.append("\n")
        out += new_lines

    config_path.write_text("".join(out), encoding="utf-8")


def restart_tint2(config_path: Path) -> None:
    """
    Kill tint2, run tint2-restart (if available),
    then start tint2 with the specified config.
    """

    # 1. Kill tint2
    for cmd in (["pkill", "-x", "tint2"], ["killall", "tint2"]):
        if _which(cmd[0]):
            subprocess.run(cmd, check=False,
                           stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL)
            break

    # Small delay so processes actually die
    time.sleep(0.3)

    # 2. Run tint2-restart if available
    if _which("tint2-restart"):
        subprocess.run(["tint2-restart"],
                       check=False,
                       stdout=subprocess.DEVNULL,
                       stderr=subprocess.DEVNULL)
        time.sleep(0.3)

    # 3. Launch tint2 with your config
    if not _which("tint2"):
        raise RuntimeError("tint2 not found in PATH")

    subprocess.Popen(
        ["tint2", "-c", str(config_path)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )
    
def apply_system_icon(root: tk.Tk):

    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk

        theme = Gtk.IconTheme.get_default()
        info = theme.lookup_icon("xfce4-session", 64, 0)
        if info:
            pixbuf = info.load_icon()
            ok, png_bytes = pixbuf.save_to_bufferv("png", [], [])
            if ok:
                img = tk.PhotoImage(data=png_bytes)
                root.iconphoto(True, img)
                root._icon_ref = img  # keep reference
    except Exception:
        pass    


class App(tk.Tk):
    def __init__(self, config_path: Path):
        super().__init__()
        self.title("enBox Launchbar Editor")
        self.geometry("720x480")
        self.minsize(640, 360)
        apply_system_icon(self)
        self.config_path = config_path
        self.items: list[LauncherItem] = []
        self._img_refs: dict[str, tk.PhotoImage] = {}  # prevent GC

        self._build_ui()
        self.load_items()

    def _build_ui(self):
        top = ttk.Frame(self, padding=10)
        top.pack(fill="both", expand=True)

        title = ttk.Frame(top)
        title.pack(fill="x", pady=10)
        ttk.Label(title, text="enBox Launchbar Editor", justify="left", font=("Sans", 14, "bold")).pack(side="left")

        header = ttk.Frame(top)
        header.pack(fill="x", pady=(0, 8))
        ttk.Label(header, text="Launchbar config file: ").pack(side="left")

        self.path_var = tk.StringVar(value=str(self.config_path))
        ttk.Entry(header, textvariable=self.path_var, state="readonly").pack(side="left", fill="x", expand=True, padx=8)
        ttk.Button(header, text="Reload", command=self.load_items).pack(side="left")

        body = ttk.Frame(top)
        body.pack(fill="both", expand=True)

        style = ttk.Style()
        style.configure("Treeview", rowheight=24)

        # Treeview with icon + name + path
        self.tree = ttk.Treeview(body, columns=("name", "path"), show="tree headings", selectmode="browse")
        self.tree.heading("#0", text="")
        self.tree.heading("name", text="Application")
        self.tree.heading("path", text="Launcher")
        self.tree.column("#0", width=60, anchor="center", stretch=False)
        self.tree.column("name", width=220, anchor="w")
        self.tree.column("path", width=380, anchor="w")

        yscroll = ttk.Scrollbar(body, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=yscroll.set)

        self.tree.pack(side="left", fill="both", expand=True)
        yscroll.pack(side="left", fill="y")

        controls = ttk.Frame(top)
        controls.pack(fill="x", pady=(8, 0))

        ttk.Button(controls, text="Add…", command=self.add_item).pack(side="left")
        ttk.Button(controls, text="Remove", command=self.remove_item).pack(side="left", padx=(8, 0))
        ttk.Separator(controls, orient="vertical").pack(side="left", fill="y", padx=10)
        ttk.Button(controls, text="Move Up", command=lambda: self.move_selected(-1)).pack(side="left")
        ttk.Button(controls, text="Move Down", command=lambda: self.move_selected(1)).pack(side="left", padx=(8, 0))

        #ttk.Separator(controls, orient="vertical").pack(side="left", fill="y", padx=10)
        #ttk.Button(controls, text="Save", command=self.save).pack(side="left")
        ttk.Button(controls, text="Save Changes", command=self.save_and_restart).pack(side="right", padx=(8, 0))

        footer = ttk.Frame(top)
        footer.pack(fill="x", pady=(8, 0))
        self.status = tk.StringVar(value="")
        ttk.Label(footer, textvariable=self.status).pack(side="left")

    def set_status(self, msg: str):
        self.status.set(msg)

    def load_items(self):
        self.config_path = Path(self.path_var.get()).expanduser()
        self._img_refs.clear()
        self.items.clear()
        self.tree.delete(*self.tree.get_children())

        if not self.config_path.exists():
            self.set_status(f"Config not found: {self.config_path}")
            return

        launcher_paths = parse_tint2_launchers(self.config_path)
        for p in launcher_paths:
            name, icon_key = read_desktop_entry(p) if p.exists() else (p.stem, "")
            icon_path = resolve_icon(icon_key) if icon_key else None
            self.items.append(LauncherItem(desktop_path=p, name=name, icon_key=icon_key, icon_path=icon_path))

        self._render_tree()
        self.set_status(f"Loaded {len(self.items)} item(s).")

    def _render_tree(self):
        self.tree.delete(*self.tree.get_children())
        for idx, item in enumerate(self.items):
            img = self._load_icon_image(item.icon_path, key=f"row{idx}")
            # Use tree column (#0) for icon
            self.tree.insert("", "end", iid=str(idx), text="", image=img, values=(item.name, str(item.desktop_path)))

    def _load_icon_image(self, icon_path: Path | None, key: str) -> tk.PhotoImage | str:
        if not icon_path or not icon_path.exists():
            return ""

        try:
            img = Image.open(icon_path)

            # Ensure RGBA so transparency works
            img = img.convert("RGBA")

            # Resize cleanly to 16x16 using high-quality resampling
            img = img.resize((16, 16), Image.Resampling.LANCZOS)

            tk_img = ImageTk.PhotoImage(img)
            self._img_refs[key] = tk_img  # prevent garbage collection
            return tk_img

        except Exception:
            return ""

    def _selected_index(self) -> int | None:
        sel = self.tree.selection()
        if not sel:
            return None
        try:
            return int(sel[0])
        except ValueError:
            return None

    def move_selected(self, delta: int):
        i = self._selected_index()
        if i is None:
            return
        j = i + delta
        if j < 0 or j >= len(self.items):
            return
        self.items[i], self.items[j] = self.items[j], self.items[i]
        self._render_tree()
        self.tree.selection_set(str(j))
        self.tree.see(str(j))
        self.set_status("Reordered (not saved yet).")

    def remove_item(self):
        i = self._selected_index()
        if i is None:
            return
        item = self.items[i]
        if not messagebox.askyesno("Remove item", f"Remove '{item.name}'?"):
            return
        del self.items[i]
        self._render_tree()
        self.set_status("Removed (not saved yet).")

    def add_item(self):
        initial = str(Path("~/.local/share/applications").expanduser())
        fp = filedialog.askopenfilename(
            title="Choose a .desktop file",
            initialdir=initial if Path(initial).exists() else str(Path.home()),
            filetypes=[("Desktop files", "*.desktop"), ("All files", "*.*")],
        )
        if not fp:
            return
        p = Path(fp).expanduser()

        name, icon_key = read_desktop_entry(p) if p.exists() else (p.stem, "")
        icon_path = resolve_icon(icon_key) if icon_key else None
        self.items.append(LauncherItem(desktop_path=p, name=name, icon_key=icon_key, icon_path=icon_path))
        self._render_tree()
        self.tree.selection_set(str(len(self.items) - 1))
        self.tree.see(str(len(self.items) - 1))
        self.set_status("Added (not saved yet).")

    def save(self):
        try:
            write_tint2_launchers(self.config_path, [it.desktop_path for it in self.items])
            self.set_status("Saved. (Backup created next to config.)")
        except Exception as e:
            messagebox.showerror("Save failed", str(e))

    def save_and_restart(self):
        self.save()
        try:
            restart_tint2(self.config_path)
            self.set_status("tint2 restarted.")
        except Exception as e:
            messagebox.showerror("Restart failed", str(e))


def main():
    cfg = CONFIG_DEFAULT
    if len(sys.argv) > 1:
        cfg = Path(sys.argv[1]).expanduser()

    app = App(cfg)
    app.mainloop()


if __name__ == "__main__":
    main()